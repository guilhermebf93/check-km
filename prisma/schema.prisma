generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id          String   @id @default(uuid())
  supabaseId  String   @unique
  name        String?
  email       String   @unique
  avatarUrl   String?

  vehicles Vehicle[]

  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model Vehicle {
  id String @id @default(uuid())

  userId String
  user   User   @relation(fields: [userId], references: [id])

  name  String
  brand String
  model String

  year      Int
  currentKm Int

  type VehicleType

  photoUrl String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

enum VehicleType {
  CAR
  MOTORCYCLE
}
